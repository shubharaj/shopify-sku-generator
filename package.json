  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "winston": "^3.13.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "prettier": "^3.3.2"
  }
}