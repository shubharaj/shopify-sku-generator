# ============================================
# Shopify SKU Generator - Environment Config
# ============================================

# REQUIRED: Your Shopify store domain (e.g., your-store.myshopify.com)
SHOPIFY_SHOP_DOMAIN=

# REQUIRED: Client ID from Shopify Dev Dashboard (starts with shpss_)
# Get this from: partners.shopify.com -> Apps -> Your App -> Settings
SHOPIFY_CLIENT_ID=

# REQUIRED: Client Secret from Shopify Dev Dashboard
# Get this from: partners.shopify.com -> Apps -> Your App -> Settings
SHOPIFY_CLIENT_SECRET=

# API Version (default: 2026-04)
API_VERSION=2026-04

# Batch size for mutation batches (1-250, default: 100)
# Lower = safer for rate limits, Higher = faster throughput
BATCH_SIZE=100

# Logging level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Dry run mode: true = log only, no actual API mutations (default: false)
DRY_RUN=false

# Max retry attempts for throttled requests (default: 5)
MAX_RETRIES=5

# Retry delay base in ms (default: 1000)
RETRY_DELAY_BASE=1000

# Progress log interval in seconds (default: 30)
PROGRESS_INTERVAL=30
